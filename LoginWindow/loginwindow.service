[Unit]
Description=Gershwin Login Window
After=systemd-user-sessions.service dshelper.service
Wants=dshelper.service
Conflicts=getty@tty1.service plymouth-quit.service
After=plymouth-quit.service

[Service]
Type=simple
ExecStart=/bin/sh -c '. /System/Library/Makefiles/GNUstep.sh && exec /System/Library/Scripts/LoginWindow.sh'
Restart=on-failure

[Install]
WantedBy=graphical.target
Alias=display-manager.service
